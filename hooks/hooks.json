{
  "description": "Claude Pulse Lean — metrics-only session and tool tracking",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hook/claude-pulse-hook.sh",
            "timeout": 3,
            "statusMessage": "Pulse: session start"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash|Agent|Skill|Read|Glob|Grep|WebFetch|WebSearch|ToolSearch",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hook/claude-pulse-hook.sh",
            "timeout": 3,
            "async": true,
            "statusMessage": "Pulse: tracking"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hook/claude-pulse-hook.sh",
            "timeout": 5,
            "async": true,
            "statusMessage": "Pulse: finalizing"
          }
        ]
      }
    ]
  }
}
